        "title": "Total Logins",
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "name": "query1",
                "data_source": "logs",
                "search": {
                  "query": "service:keycloak \"org.keycloak.events\" type=LOGIN $environment $realm"
                },
                "indexes": [
                  "*"
                ],
                "group_by": [],
                "compute": {
                  "aggregation": "count"
                },
                "storage": "hot"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0
